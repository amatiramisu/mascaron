<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <AssemblyTitle>Mascaron</AssemblyTitle>
    <Version>0.2.0.0</Version>
    <Description>Face bone sculpting tool</Description>
    <RootNamespace>Mascaron</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="Assets\Faces\*.png" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
